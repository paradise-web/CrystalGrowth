# 下载APK
from google.colab import files
import os

apk_files = [f for f in os.listdir('bin') if f.endswith('.apk')]
if apk_files:
    print(f"Found APK files: {apk_files}")
    for apk in apk_files:
        files.download(os.path.join('bin', apk))
else:
    print("No APK files found. Check build logs.")
